# ── Required ───────────────────────────────────────────────────────────────
# Perplexity API key — single shared key (owner pays for all users)
PERPLEXITY_API_KEY=your_perplexity_key_here

# Supabase project URL (https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase JWT secret (Settings → API → JWT Secret in Supabase dashboard)
# Used to verify Authorization: Bearer <jwt> headers from the React frontend.
SUPABASE_JWT_SECRET=your_jwt_secret

# Fernet symmetric key for PII encryption (e.g. requester_email).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Flask secret key (cookies, CSRF). Generate with `python -c "import secrets; print(secrets.token_hex(32))"`
FLASK_SECRET_KEY=

# ── Recommended ────────────────────────────────────────────────────────────
# Redis URL for rate limiting. Default `memory://` works locally but is per-process —
# production MUST use redis://... (Upstash free tier or Render Redis add-on).
REDIS_URL=memory://

# Comma-separated origins allowed to call the API. Includes Lovable preview + custom domains.
CORS_ORIGINS=https://hawsh-khalifa.lovable.app,http://localhost:5173,http://localhost:8080

# Comma-separated Supabase user IDs that may call /api/admin/*
ADMIN_USER_IDS=

# ── Tuning ─────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER_DAY=5/day
RATE_LIMIT_PER_IP_MINUTE=30/minute
PERPLEXITY_DEFAULT_MODEL=sonar-pro
SHARE_TOKEN_EXPIRY_DAYS=180
SSE_TIMEOUT_SECONDS=300
PENDING_TTL_SECONDS=600

# ── Local dev ──────────────────────────────────────────────────────────────
FLASK_DEBUG=false
LOG_LEVEL=INFO
PORT=5000
ENABLE_CLEANUP_SCHEDULER=1

# ── Optional fallback AI providers (kept in agents/base.py PROVIDERS) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Optional data source APIs (have embedded fallbacks) ────────────────────
SIJILAT_API_KEY=
TRADING_ECONOMICS_API_KEY=
